default_platform(:ios)

PROJECT = "stash/stash.xcodeproj"
SCHEME = "stash"

platform :ios do
  # Authenticates with App Store Connect using an API key (recommended — no 2FA).
  # Set ASC_KEY_ID, ASC_ISSUER_ID and ASC_KEY_CONTENT (base64 of the .p8) in the
  # environment. See fastlane/README.md.
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true
    )
  end

  desc "Build and upload a new build to TestFlight"
  lane :beta do
    api_key = asc_api_key

    # Use one above the highest build already on TestFlight, so every upload is unique.
    next_build = latest_testflight_build_number(api_key: api_key, initial_build_number: 0) + 1
    increment_build_number(xcodeproj: PROJECT, build_number: next_build)

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "build",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Run the unit tests (same as CI)"
  lane :tests do
    run_tests(
      project: PROJECT,
      scheme: SCHEME,
      only_testing: ["stashTests"]
    )
  end
end
